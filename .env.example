# GitHub App credentials (user-to-server flow)
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# Optional: installation page URL, used when app is not installed yet
# APP_INSTALL_URL=https://github.com/apps/your-app-slug/installations/new

# Optional
# PORT=8080

# Optional: comma-separated CORS origins for browser clients
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
# In non-production mode, localhost dev origins are allowed by default.
# CORS_ALLOWED_ORIGINS=
