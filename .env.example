# GitHub App credentials (user-to-server flow)
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# Required for production outside Vercel so secure cross-site cookies are used.
# On Vercel, VERCEL_ENV=production is provided automatically.
# NODE_ENV=production

# Required in production when your backend is publicly deployed.
# Example: OAUTH_CALLBACK_URL=https://op-bot-mauve.vercel.app/auth/github/callback
OAUTH_CALLBACK_URL=

# Required when frontend and backend are on different origins.
# Example: CORS_ALLOWED_ORIGINS=https://oneclick-portfolio.github.io,http://localhost:4173,http://localhost:5173
CORS_ALLOWED_ORIGINS=

# Required for deploy flow and bot commits.
# APP_ID is the numeric App ID from https://github.com/settings/apps/<your-app>
# APP_PRIVATE_KEY is the PEM private key content with newlines as \n or real newlines.
APP_ID=
APP_PRIVATE_KEY=

# Optional: installation page URL, used when app is not installed yet
APP_INSTALL_URL=https://github.com/apps/oneclick-portfolio-bot

# Optional: Backend server port
# PORT=8080

# Optional: source repository/ref for portfolio themes used during deploy
# THEME_SOURCE_REPO=oneclick-portfolio/awesome-github-portfolio
# THEME_SOURCE_REF=main

