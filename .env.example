# GitHub App credentials (user-to-server flow)
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# Optional: installation page URL, used when app is not installed yet
# APP_INSTALL_URL=https://github.com/apps/your-app-slug/installations/new

# Optional: OAuth callback URL.
# In local development, defaults to http://localhost:8080/auth/github/callback
# OAUTH_CALLBACK_URL=http://localhost:8080/auth/github/callback

# Optional: Backend server port
# PORT=8080

# Optional: comma-separated CORS origins for browser clients
# Example: CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173,https://app.example.com
# Frontend and backend run as separate microservices - CORS is required
# CORS_ALLOWED_ORIGINS=

# Optional: source repository/ref for portfolio themes used during deploy
# THEME_SOURCE_REPO=oneclick-portfolio/awesome-github-portfolio
# THEME_SOURCE_REF=main

