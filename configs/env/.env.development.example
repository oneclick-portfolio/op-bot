# Development environment template
NODE_ENV=development
PORT=8080

# GitHub OAuth app (user-to-server flow)
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# GitHub App credentials for deploy/bot operations
APP_ID=
APP_PRIVATE_KEY=
APP_INSTALL_URL=https://github.com/apps/oneclick-portfolio-bot

# Local callback URL
OAUTH_CALLBACK_URL=http://localhost:8080/auth/github/callback

# Local frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173

# Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Logging
LOG_LEVEL=debug
