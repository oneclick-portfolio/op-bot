# Production environment template
NODE_ENV=production
PORT=8080

# GitHub OAuth app (user-to-server flow)
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# Public callback URL for your deployed backend
# Example: https://op-bot.example.com/auth/github/callback
OAUTH_CALLBACK_URL=

# Frontend origins allowed to call this API
# Example: https://oneclick-portfolio.github.io
CORS_ALLOWED_ORIGINS=

# GitHub App credentials for deploy/bot operations
APP_ID=
APP_PRIVATE_KEY=
APP_INSTALL_URL=https://github.com/apps/oneclick-portfolio-bot

# Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Logging
LOG_LEVEL=info
