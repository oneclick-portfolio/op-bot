{
    "swagger": "2.0",
    "info": {
        "description": "Backend API for portfolio deployment with GitHub OAuth and resume validation. Runs as a microservice separate from the frontend.",
        "title": "Op-Bot API",
        "contact": {},
        "version": "1.0.0"
    },
    "basePath": "/",
    "paths": {
        "/api/github/deploy": {
            "post": {
                "description": "Creates a GitHub repository and deploys the selected theme",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "github"
                ],
                "summary": "Deploy portfolio theme",
                "parameters": [
                    {
                        "description": "Deploy parameters",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.DeployParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.DeployResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/github/logout": {
            "post": {
                "description": "Clears the GitHub auth cookie",
                "tags": [
                    "github"
                ],
                "summary": "Logout from GitHub",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                }
            }
        },
        "/api/github/me": {
            "get": {
                "description": "Returns the authenticated GitHub user and app installation info",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "github"
                ],
                "summary": "Get current GitHub user",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.MeResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/github/repos": {
            "get": {
                "description": "Returns the repositories the GitHub app has access to",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "github"
                ],
                "summary": "Get current GitHub installations repositories",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    },
                    "502": {
                        "description": "Unable to load repositories",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/resume/parse": {
            "post": {
                "description": "Extracts resume data from a PDF file using AI and returns v5 schema JSON",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resume"
                ],
                "summary": "Parse resume PDF to JSON",
                "parameters": [
                    {
                        "type": "file",
                        "description": "Resume PDF file (max 5MB)",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/resume/validate": {
            "post": {
                "description": "Validates resume data against the RxResume schema",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resume"
                ],
                "summary": "Validate resume JSON",
                "parameters": [
                    {
                        "description": "Resume JSON data to validate",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.ValidateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.ValidationResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/github/callback": {
            "get": {
                "description": "Handles OAuth callback from GitHub and sets auth cookie",
                "tags": [
                    "auth"
                ],
                "summary": "GitHub OAuth callback",
                "parameters": [
                    {
                        "type": "string",
                        "description": "OAuth code",
                        "name": "code",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "OAuth state",
                        "name": "state",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Found"
                    },
                    "400": {
                        "description": "Invalid OAuth state",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    },
                    "500": {
                        "description": "OAuth callback failed",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/github/start": {
            "get": {
                "description": "Redirects to GitHub for OAuth authorization",
                "tags": [
                    "auth"
                ],
                "summary": "Start GitHub OAuth flow",
                "parameters": [
                    {
                        "type": "string",
                        "description": "URL to return to after auth",
                        "name": "returnTo",
                        "in": "query"
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Found"
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/models.APIErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.APIErrorPayload": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "details": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "models.APIErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/models.APIErrorPayload"
                }
            }
        },
        "models.DeployParams": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "homepageUrl": {
                    "type": "string"
                },
                "privateRepo": {
                    "type": "boolean"
                },
                "repositoryName": {
                    "type": "string"
                },
                "repositoryOwner": {
                    "type": "string"
                },
                "resumeData": {},
                "theme": {
                    "type": "string"
                },
                "themeRepoLink": {
                    "type": "string"
                },
                "useGitHubPagesUrl": {
                    "type": "boolean"
                }
            }
        },
        "models.DeployResult": {
            "type": "object",
            "properties": {
                "installationId": {},
                "pagesUrl": {
                    "type": "string"
                },
                "repoFullName": {
                    "type": "string"
                },
                "repositoryUrl": {
                    "type": "string"
                },
                "reusedExistingRepo": {
                    "type": "boolean"
                }
            }
        },
        "models.GitHubAppInfo": {
            "type": "object",
            "properties": {
                "installUrl": {
                    "type": "string",
                    "example": "https://github.com/apps/myapp"
                },
                "installationId": {
                    "type": "integer",
                    "example": 12345
                },
                "installed": {
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "models.GitHubUser": {
            "type": "object",
            "properties": {
                "avatarUrl": {
                    "type": "string",
                    "example": "https://github.com/images/octocat.png"
                },
                "login": {
                    "type": "string",
                    "example": "octocat"
                },
                "name": {
                    "type": "string",
                    "example": "The Octocat"
                }
            }
        },
        "models.MeResponse": {
            "type": "object",
            "properties": {
                "githubApp": {
                    "$ref": "#/definitions/models.GitHubAppInfo"
                },
                "user": {
                    "$ref": "#/definitions/models.GitHubUser"
                }
            }
        },
        "models.ValidateRequest": {
            "type": "object",
            "properties": {
                "resumeData": {}
            }
        },
        "models.ValidationResult": {
            "type": "object",
            "properties": {
                "errors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "valid": {
                    "type": "boolean",
                    "example": true
                }
            }
        }
    }
}